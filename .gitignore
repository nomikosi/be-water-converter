# ============================================================
#  IntelliJ Platform Plugin — .gitignore
#  Covers: Gradle build, IntelliJ IDE metadata, Java/Kotlin,
#          OS artefacts, test output, and sandbox directories.
# ============================================================

# ── Gradle ───────────────────────────────────────────────────
.gradle/
build/
out/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ── IntelliJ Plugin Sandbox (auto-generated per run) ────────
# Created by Gradle IntelliJ Plugin when running runIde / buildPlugin
.idea-sandbox/
sandbox/
run/

# ── IntelliJ IDEA project metadata ──────────────────────────
# Commit: .idea/modules.xml, .idea/runConfigurations/ (custom runs),
#         .idea/copyright/, .idea/scopes/ — these are team-shareable.
# Ignore everything else:
.idea/
!.idea/modules.xml
!.idea/runConfigurations/
!.idea/copyright/
!.idea/scopes/
!.idea/vcs.xml
!.idea/codeStyles/

# Module files (regenerated by Gradle)
*.iml
*.ipr
*.iws

# ── Compiled output ──────────────────────────────────────────
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar

# ── Plugin distribution artefacts ───────────────────────────
# Generated by ./gradlew buildPlugin
distributions/
*.zip

# ── Test & coverage reports ──────────────────────────────────
test-results/
reports/
jacoco/
*.exec
*.ec
coverage/
html/

# ── Kotlin ───────────────────────────────────────────────────
*.kotlin_module
kotlin-js-store/

# ── Maven (if mixed build) ───────────────────────────────────
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
release.properties

# ── OS artefacts ─────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ── Editor & tool artefacts ──────────────────────────────────
*.swp
*.swo
*.orig
*.bak
*.tmp
*.log
*.pid

# ── Environment / secrets ─────────────────────────────────────
.env
.env.*
*.local
local.properties
secrets.properties

# ── Node / frontend (if any tooling) ────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
package-lock.json

# ── Gradle cache hints ───────────────────────────────────────
# Keep gradle/wrapper tracked; ignore local caches
.gradle/caches/
.gradle/wrapper/dists/
gradle-app.setting

# ── JetBrains Toolbox / Fleet ───────────────────────────────
.fleet/

# ── IntelliJ Platform Gradle Plugin specifics ────────────────
# intellijPlatform {} downloads and caches — never commit these
*/platformDownloadDir/
*/instrumentedJars/
*/preparedSandboxTask/
.intellijPlatform


