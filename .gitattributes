# Normalize line endings: text files use LF in the repository.
* text=auto

# The Gradle wrapper script must stay LF — CRLF breaks it on Linux/macOS.
gradlew text eol=lf
*.sh    text eol=lf

# Windows batch files need CRLF.
*.bat   text eol=crlf

# Binary files.
*.jar   binary
*.png   binary
*.zip   binary
